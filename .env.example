PORT=8080

# JWT
JWT_SECRET=your-secret-or-public-key
JWT_ISSUER=
JWT_AUDIENCE=

# Timeouts
AUTH_TIMEOUT_SECONDS=5
IDLE_TIMEOUT_SECONDS=90
MAX_CONNECTION_LIFETIME_SECONDS=1800
MAX_UNAUTH_PER_IP=10

# AI agent HTTP API
AI_SERVER_ADDRESS=http://localhost:8001
AI_REQUEST_TIMEOUT_MS=30000

# CRUD / HITL backend API
CRUD_SERVER_ADDRESS=https://api.zoft.ai
CRUD_REQUEST_TIMEOUT_MS=10000

# Supabase (for helpdesk Supabase JWT auth)
# When set, WSS accepts Supabase access tokens; fetches workspace from CRUD for tenant_id
SUPABASE_URL=https://your-project.supabase.co
# JWT secret from Supabase: Project Settings > API > JWT Secret
# Required when JWKS returns empty keys (legacy Supabase projects)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
